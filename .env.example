# Anthropic — Prompt Forge + Intelligence Engine
ANTHROPIC_API_KEY=

# Helius — transaction webhooks
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
# Deployed base URL (no trailing slash). On Railway, RAILWAY_PUBLIC_DOMAIN is used automatically if unset.
PUBLIC_URL=

# Supabase — operator fingerprint DB (run supabase/schema.sql first)
SUPABASE_URL=https://your-project.supabase.co/rest/v1
SUPABASE_SERVICE_KEY=

# Redis — alert queue (optional; SQLite is fallback)
REDIS_URL=redis://localhost:6379

# Telegram — alert delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHANNEL_ID=
TELEGRAM_PRO_CHANNEL_ID=
TELEGRAM_FREE_CHANNEL_ID=

# Solana — proof-of-prediction memos
CABALSCAN_WALLET_PRIVATE_KEY=

# Server
PORT=3847
